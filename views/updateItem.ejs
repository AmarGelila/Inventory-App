<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update item</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <main>
      <h1>Update Item</h1>
      <% if ( locals.errorMessage ) {%>
        <%- include("snippets/errorMessage", {errorMessage: locals.errorMessage}) %>
      <% } %>
      <form action="" method="post">
        <input type="hidden" name="_method" value="PUT" />
        <label for="item-name">Item Name:-</label>
        <input type="text" name="itemName" id="item-name" value="<%= locals?.item?.name || '' %>" />
        <%- include("snippets/formError",{name: "itemName"}) %>
        <label for="quantity">Quantity:- </label>
        <input type="number" name="quantity" id="quantity" value="<%= locals?.item?.quantity || 0 %>" />
        <%- include("snippets/formError",{name: "quantity"}) %>

        <label for="price">Price:- </label>
        <input type="number" name="price" id="price" value="<%= locals?.item?.price || 0 %>" />
        <%- include("snippets/formError",{name: "price"}) %>

        <label for="description">Description</label>
        <textarea name="description" id="description"><%= locals?.item?.description || "" %></textarea>
        <%- include("snippets/formError",{name: "description"}) %>

        <button type="submit">Update Item</button>
      </form>

    </main>
  </body>
</html>
